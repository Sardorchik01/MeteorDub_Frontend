// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - username: string (required, unique)
//   - firstName: string
//   - lastName: string
//   - birthYear: number
//   - role: string (user, uploader, support, superadmin)
//   - status: string (standard, premium)
//   - createdAt: number
//
// Collection: usernames
// Document ID: {username}
// Fields:
//   - email: string
//   - uid: string
//
// Collection: animes
// Document ID: {animeId}
// Fields:
//   - title: string (required)
//   - description: string
//   - thumbnail: string
//   - videoUrl: string (required)
//   - genre: list
//   - rating: number
//   - episodes: number
//   - status: string
//   - year: number
//   - accessType: string (public, premium)
//   - upgradeLink: string
//
// Collection: stats
// Document ID: {statId}
// Fields:
//   - date: string
//   - views: number
//   - subscriptions: number
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email.lower() == "abdulazizov0117@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['uploader', 'support', 'superadmin'])
      );
    }

    function isSuperAdmin() {
      return (request.auth.token.email.lower() == "abdulazizov0117@gmail.com" && request.auth.token.email_verified == true) || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    function isUploader() {
      return hasRole('uploader') || isSuperAdmin();
    }

    function isSupport() {
      return hasRole('support') || isSuperAdmin();
    }

    function isPremium() {
      return isAuthenticated() && getUserData().status == 'premium';
    }

    // Validation Helpers
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'username', 'role', 'status']) &&
             data.uid is string &&
             data.email is string &&
             data.username is string && data.username.size() >= 3 &&
             data.role in ['user', 'uploader', 'support', 'superadmin'] &&
             data.status is string;
    }

    function isValidAnime(data) {
      return data.keys().hasAll(['title', 'videoUrl', 'accessType']) &&
             data.title is string && data.title.size() < 200 &&
             data.videoUrl is string &&
             data.accessType is string;
    }

    function isValidTariff(data) {
      return data.keys().hasAll(['name', 'redirectUrl']) &&
             data.name is string && data.redirectUrl is string;
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['uid', 'name', 'animeIds']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.animeIds is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /usernames/{username} {
      // Anyone can read to check for uniqueness or look up email.
      allow read: if true;
      // Create: Only if it doesn't exist.
      allow create: if isAuthenticated() && !exists(/databases/$(database)/documents/usernames/$(username)) && request.resource.data.uid == request.auth.uid;
      // Update/Delete: Not allowed to prevent hijacking.
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Users can read their own profile. Support and SuperAdmin can read all.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      // Create: User can create their own profile as 'user' and 'standard'.
      // SuperAdmin can create any.
      allow create: if (isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.status == 'standard' && isValidUser(request.resource.data)) || isSuperAdmin();
      
      // Update: User can update their own info but NOT role/status.
      // Support can update info and status.
      // SuperAdmin can update everything.
      // CRITICAL: NO ONE can change the role of the hardcoded superadmin.
      allow update: if (isSuperAdmin() && (userId != request.auth.uid || request.resource.data.role == 'superadmin')) ||
                    (isSupport() && userId != request.auth.uid && isValidUser(request.resource.data)) ||
                    (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.status == resource.data.status && isValidUser(request.resource.data));
      
      // Delete: Only SuperAdmin, but NOT the hardcoded one.
      allow delete: if isSuperAdmin() && request.auth.token.email.lower() != get(/databases/$(database)/documents/users/$(userId)).data.email.lower();
    }

    match /ads/{adId} {
      // Anyone can read enabled ads.
      allow read: if true;
      // Only SuperAdmin can manage ads.
      allow write: if isSuperAdmin();
    }

    match /ai_configs/{configId} {
      // Only SuperAdmin can manage AI configs.
      allow read, write: if isSuperAdmin();
    }

    match /animes/{animeId} {
      // Everyone can read animes (to see them in the list).
      allow read: if true;
      
      // Write: Uploader and SuperAdmin.
      allow create, update: if isUploader() && isValidAnime(request.resource.data);
      allow delete: if isUploader();
    }

    match /tariffs/{tariffId} {
      // Everyone can read tariffs to see upgrade options.
      allow read: if true;
      // Write: SuperAdmin only.
      allow create, update: if isSuperAdmin() && isValidTariff(request.resource.data);
      allow delete: if isSuperAdmin();
    }

    match /playlists/{playlistId} {
      // Users can read their own playlists.
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      // Create: Authenticated users can create their own.
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidPlaylist(request.resource.data);
      // Update/Delete: Only owners.
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid && isValidPlaylist(request.resource.data);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    match /notifications/{notificationId} {
      // Users can read their own notifications.
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || resource.data.userId == 'all');
      // Create: Admins can send notifications.
      allow create: if isAdmin();
      // Update: Users can mark their own as read.
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    match /stats/{statId} {
      // Admins can read stats.
      allow read: if isAdmin();
      
      // SuperAdmin can write stats (or a backend process).
      allow write: if isSuperAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
