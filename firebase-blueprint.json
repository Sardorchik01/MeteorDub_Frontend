{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string", "description": "Unique username" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "birthYear": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "uploader", "support", "superadmin"] },
        "status": { "type": "string", "description": "standard or tariff ID" },
        "tariffId": { "type": "string", "description": "ID of the active tariff" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["uid", "email", "username", "role", "status"]
    },
    "Anime": {
      "title": "Anime",
      "description": "Stores anime metadata and video links.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnail": { "type": "string", "format": "uri" },
        "videoUrl": { "type": "string", "format": "uri" },
        "genre": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number", "description": "IMDb rating" },
        "episodes": { "type": "number" },
        "status": { "type": "string", "enum": ["Ongoing", "Completed"] },
        "year": { "type": "number" },
        "accessType": { "type": "string", "description": "public or tariff ID" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "videoUrl", "accessType"]
    },
    "Tariff": {
      "title": "Tariff",
      "description": "Subscription plans.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "buttonLabel": { "type": "string" },
        "redirectUrl": { "type": "string" },
        "price": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "redirectUrl"]
    },
    "Stats": {
      "title": "Statistics",
      "description": "Stores site-wide statistics.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "views": { "type": "number" },
        "subscriptions": { "type": "number" }
      }
    },
    "Playlist": {
      "title": "Playlist",
      "description": "User-created anime playlists.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "animeIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "name", "animeIds"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/animes/{animeId}": {
      "schema": "Anime",
      "description": "Anime catalog."
    },
    "/tariffs/{tariffId}": {
      "schema": "Tariff",
      "description": "Subscription plans."
    },
    "/playlists/{playlistId}": {
      "schema": "Playlist",
      "description": "User anime playlists."
    },
    "/notifications/{notificationId}": {
      "schema": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "title": { "type": "string" },
          "message": { "type": "string" },
          "type": { "type": "string" },
          "read": { "type": "boolean" },
          "createdAt": { "type": "number" }
        }
      },
      "description": "User notifications."
    },
    "/usernames/{username}": {
      "schema": {
        "type": "object",
        "properties": {
          "email": { "type": "string" },
          "uid": { "type": "string" }
        }
      },
      "description": "Mapping of usernames to emails for unique check and login."
    }
  }
}
